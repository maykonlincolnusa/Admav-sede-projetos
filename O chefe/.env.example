APP_NAME=ADMAV AI CHURCH SYSTEM
APP_ENV=development
TIMEZONE=America/Sao_Paulo
LOG_LEVEL=INFO
EXPOSE_DOCS=true
ALLOWED_ORIGINS=["http://localhost:5173"]

MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=admav_ai_church
MONGODB_MEMBERS_COLLECTION=members
MONGODB_KNOWLEDGE_COLLECTION=knowledge_base
MONGODB_INTERACTIONS_COLLECTION=interactions

LLM_PROVIDER=google
GOOGLE_API_KEY=
GOOGLE_CHAT_MODEL=gemini-2.5-flash
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=google
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

SCHEDULER_DEVOTIONAL_DAYS=mon,wed,fri
SCHEDULER_DEVOTIONAL_HOUR=7
SCHEDULER_DEVOTIONAL_MINUTE=0
DEFAULT_SEARCH_K=4
